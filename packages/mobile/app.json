{
  "expo": {
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.deutschforge_d4k2.runable",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1B2A"
      },
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "apiUrl": "https://deutschforge3.onrender.com",
      "eas": {}
    },
    "ios": {
      "bundleIdentifier": "com.deutschforge_d4k2.runable",
      "supportsTablet": true
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0D1B2A"
    },
    "name": "MoinMoin",
    "slug": "deutschforge",
    "version": "1.0.0",
    "scheme": "deutschforge",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ]
  }
}